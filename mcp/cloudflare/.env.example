# Cloudflare API credentials — never commit real values
# Copy to .env and fill in from Cloudflare Dashboard

# API token with least-privilege scopes:
#   Account: Cloudflare Pages (Edit), Account Settings (Read)
#   Zone: DNS (Edit), Zone (Read)
CLOUDFLARE_API_TOKEN=

# Account ID — Dashboard → Workers & Pages → right sidebar
CLOUDFLARE_ACCOUNT_ID=

# Zone ID — Dashboard → target domain → Overview → right sidebar
CLOUDFLARE_ZONE_ID=
