        "TEKNOVO_WORKSPACE": "C:/Users/fajar/Downloads/AI"
      }
    },
    "teknovo-git": {
      "command": "node",
      "args": ["C:/Users/fajar/Downloads/AI/mcp/git/server.js"],
      "env": {
        "TEKNOVO_WORKSPACE": "C:/Users/fajar/Downloads/AI"
      }
    },
    "teknovo-postgres": {
      "command": "node",
      "args": ["C:/Users/fajar/Downloads/AI/mcp/postgres/server.js"],
      "env": {
        "DATABASE_URL": "${env:DATABASE_URL}"
      }
    },
    "teknovo-qdrant": {
      "command": "node",
      "args": ["C:/Users/fajar/Downloads/AI/mcp/qdrant/server.js"],
