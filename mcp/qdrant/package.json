{
  "name": "teknovo-qdrant-mcp",
  "version": "1.0.0",
  "description": "Teknovo Qdrant MCP — vector collection search and upsert",
  "type": "module",
  "main": "server.js",
  "bin": { "teknovo-qdrant-mcp": "./server.js" },
  "scripts": {
    "start": "node server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "node scripts/lint.js",
    "check": "npm run lint && npm test"
  },
  "engines": { "node": ">=18.0.0" },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "collectCoverageFrom": ["lib/**/*.js", "tools/**/*.js", "!**/node_modules/**"],
    "coverageThreshold": {
      "global": { "branches": 65, "functions": 80, "lines": 80, "statements": 80 }
    },
    "moduleNameMapper": { "^(\\.{1,2}/.*)\\.js$": "$1" }
  },
  "keywords": ["mcp", "qdrant", "teknovo"],
  "license": "MIT"
}
