{
  "mcpServers": {
    "teknovo-cloudflare": {
      "command": "node",
      "args": ["C:/Users/fajar/Downloads/AI/mcp/cloudflare/server.js"],
      "env": {
        "CLOUDFLARE_API_TOKEN": "${env:CLOUDFLARE_API_TOKEN}",
