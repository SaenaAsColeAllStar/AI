        "CLOUDFLARE_ZONE_ID": "${env:CLOUDFLARE_ZONE_ID}"
      }
    },
    "teknovo-github": {
      "command": "node",
      "args": ["C:/Users/fajar/Downloads/AI/mcp/github/server.js"],
      "env": {
